# ═══════════════════════════════════════════════════════════
# EXPENSE TRACKER — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.development, .env.staging, or .env.production
# NEVER commit actual values to git. Use EAS Secrets for production.

# ── Firebase ──────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Firebase App Check ────────────────────────────────────
EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=
FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@sentry.io/00000
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org
SENTRY_PROJECT=expense-tracker

# ── Mixpanel ──────────────────────────────────────────────
MIXPANEL_TOKEN=your_mixpanel_token

# ── RevenueCat ────────────────────────────────────────────
REVENUECAT_API_KEY_IOS=appl_xxxxxxxx
REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxx

# ── SendGrid (iOS email parsing) ─────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_INBOUND_DOMAIN=parse.yourapp.com

# ── Google Sign-In ────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID_IOS=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID_ANDROID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID_WEB=xxxx.apps.googleusercontent.com

# ── EAS ───────────────────────────────────────────────────
EAS_PROJECT_ID=your-eas-project-id

# ── Admin Dashboard ───────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Environment ───────────────────────────────────────────
APP_ENV=development
